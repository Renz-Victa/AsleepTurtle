# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git.

# Resend API key — get one at resend.com (free tier is generous)
RESEND_API_KEY=re_your_key_here

# Your live domain — used for sitemap generation at build time
SITE_URL=https://asleepturtle.com

# Plausible analytics domain (optional)
# Add <Script defer data-domain="asleepturtle.com" src="https://plausible.io/js/script.js" />
# to app/layout.tsx once your Plausible account is set up
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=asleepturtle.com
