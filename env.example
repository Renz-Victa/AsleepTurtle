# Sawrus API — Environment Variables
# Copy to .env and fill in your values. Never commit .env.

PORT=3001
NODE_ENV=development

# ── Self-hosted CAPTCHA secret ────────────────────────────────
# Used to HMAC-sign math challenges. Use any long random string.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CAPTCHA_SECRET=replace_with_a_long_random_secret_string_here

# ── CORS allowed origins ──────────────────────────────────────
# Comma-separated list of allowed frontend origins.
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,https://sawrus.com,https://www.sawrus.com

# ── SQLite database path (created automatically) ──────────────
DB_PATH=./data/contacts.db
